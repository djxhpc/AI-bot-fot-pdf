    return pd.DataFrame(dataset)

def clean_duplicated_text(text):
    if not text:
        return ""
    text = text.replace('\xa0', ' ').replace('\u3000', ' ')
    text = re.sub(r'\s+', ' ', text)
    text = re.sub(r'([\u4e00-\u9fa5])\1+', r'\1', text)
    for _ in range(3):
        text = re.sub(r'([\u4e00-\u9fa5]{2,10})\1', r'\1', text)
        text = re.sub(r'([\u4e00-\u9fa5]{2,10})\s\1', r'\1', text)
    text = re.sub(r'([\u4e00-\u9fa5])\s\1', r'\1', text)
    return text.strip()

# --- 1. 載入 Embedding 與 Reranker 模型 ---
@st.cache_resource
def get_embedding_model():
    from langchain_huggingface import HuggingFaceEmbeddings  # ✅ 完全修正拼字
    model_name = "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
    return HuggingFaceEmbeddings(model_name=model_name)      # ✅ 完全修正拼字

@st.cache_resource
def get_reranker_model():
    from sentence_transformers import CrossEncoder
    # 使用支援多國語言（含繁中）的輕量級 Cross-Encoder 作為重排模型
    model_name = "BAAI/bge-reranker-base"
    return CrossEncoder(model_name)

# --- 2. 建立混合向量與關鍵字庫 ---
def build_vector_store(docs):
    from langchain_text_splitters import RecursiveCharacterTextSplitter
    from langchain_community.vectorstores import FAISS
    from langchain_community.retrievers import BM25Retriever
    
    text_splitter = RecursiveCharacterTextSplitter(
        chunk_size=200,        # 稍微放大 chunk，讓 Rerank 更有上下文參考價值
        chunk_overlap=100,
        length_function=len,
        separators=["\n\n", "\n", "。", " ", ""], 
    )
    split_docs = text_splitter.split_documents(docs)
    
    with st.spinner("正在建立混合索引 (FAISS 向量庫 + BM25 關鍵字庫)..."):
        # 建立 FAISS 向量庫
        vector_db = FAISS.from_documents(split_docs, get_embedding_model())
        # 建立 BM25 關鍵字檢索器
        bm25_retriever = BM25Retriever.from_documents(split_docs)
        
    # 將兩者綁定一起回傳
    return {"vector_db": vector_db, "bm25_retriever": bm25_retriever}

# --- 3. 混合檢索 (Hybrid Search) + 重排 (Reranking) 核心函式 ---
def get_relevant_context(query, hybrid_db, k_value):
    vector_db = hybrid_db["vector_db"]
    bm25_retriever = hybrid_db["bm25_retriever"]
    
    # 為了讓 Reranker 有挑選空間，初篩抓取較多候選者 (K 的 3 倍)
    candidate_k = max(k_value * 3, 15)
    
    # 1. 向量搜尋 (Dense Retrieval)
    dense_docs = vector_db.similarity_search(query, k=candidate_k)
    
    # 2. 關鍵字搜尋 (Sparse Retrieval)
    bm25_retriever.k = candidate_k
    sparse_docs = bm25_retriever.invoke(query)
    
    # 3. 混合結果並去重
    seen_contents = set()
    unique_candidates = []
    for doc in dense_docs + sparse_docs:
        if doc.page_content not in seen_contents:
            seen_contents.add(doc.page_content)
            unique_candidates.append(doc)
            
    # 4. Reranking 重排階段
    if not unique_candidates:
        return "", []
        
    reranker = get_reranker_model()
    # 建立 Cross-Encoder 輸入格式: [[query, doc1], [query, doc2], ...]
    pairs = [[query, doc.page_content] for doc in unique_candidates]
    scores = reranker.predict(pairs)
    
    # 將分數與 Document 組合，並由高到低排序
    scored_docs = sorted(zip(scores, unique_candidates), key=lambda x: x[0], reverse=True)
    
    # 5. 取出前 K 高分的菁英片段
    top_k_scored = scored_docs[:k_value]
    final_docs = [doc for score, doc in top_k_scored]
    
    st.sidebar.caption(f"⚡ 混合檢索成功！初篩 {len(unique_candidates)} 筆 ➡️ Rerank 精選 {len(final_docs)} 筆")
    
    # 回傳組合好的文本，以及包含分數的物件供前端 Debug 顯示
    context_text = "\n\n---\n\n".join([doc.page_content for doc in final_docs])
    return context_text, top_k_scored



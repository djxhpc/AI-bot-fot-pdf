                full_prompt = f"【手冊內容】：\n{search_context}\n\n當前問題：{question}"
                chat_messages = [
                    {'role': 'system', 'content': system_instruction},
                    {'role': 'user', 'content': full_prompt}
                ]
                
                status_text.text(f"正在評測第 {idx} 筆資料...")
                
                try:
                    response = chat(
                        model=target_model,
                        messages=chat_messages,
                        options={"temperature": 0.0, "num_predict": 500}
                    )
                    model_reply = response.message.content.strip()
                except Exception as e:
                    model_reply = f"模型呼叫失敗：{e}"
                
                # --- 🎯 關鍵比對邏輯 🎯 ---
                # 規則：模型回答只要「包含」任一個標準答案（複數答案中一個就算）即判定為正確
                is_correct = False
                for ans in gold_answers:
                    if str(ans).strip() in model_reply:
                        is_correct = True
                        break # 中一個就夠了，跳出迴圈
                
                # 記錄結果
                updated_notes.at[idx, "模型回答"] = model_reply
                if is_correct:
                    updated_notes.at[idx, "比對結果"] = "✅ 正確"
                    correct_count += 1
                else:
                    updated_notes.at[idx, "比對結果"] = "❌ 錯誤"
                    
                # 更新進度條
                progress_bar.progress((idx - start_idx + 1) / total_tested)
            
            # 將結果更新回 Session State 並重新整理畫面
            st.session_state.test_notes = updated_notes
            status_text.empty()
            progress_bar.empty()
            
            # 顯示統計數據
            accuracy = (correct_count / total_tested) * 100
            st.success(f"📊 測試完成！區間：{start_idx} ~ {end_idx} | 答對題數：{correct_count}/{total_tested} | 準確度：{accuracy:.2f}%")

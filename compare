        # 讓使用者選擇要測試的資料範圍
        col_range1, col_range2 = st.columns(2)
        with col_range1:
            start_idx = st.number_input("測試起始 Index", min_value=0, max_value=len(df_test)-1, value=0)
        with col_range2:
            end_idx = st.number_input("測試結束 Index", min_value=start_idx, max_value=len(df_test)-1, value=min(start_idx + 4, len(df_test)-1))
            
        if st.button("🚀 開始批量測試與比對答案"):
            # 建立進度條
            progress_bar = st.progress(0.0)
            status_text = st.empty()
            
            # 複製一份現有的資料庫來儲存評測結果
            updated_notes = st.session_state.test_notes.copy()
            
            correct_count = 0
            total_tested = end_idx - start_idx + 1
            
            # 遍歷指定範圍的測資
            for idx in range(start_idx, end_idx + 1):
                row = df_test.iloc[idx]
                context = row.get('context', row.get('paragraph', ''))
                question = row['question']
                
                # 處理複數答案的情況（TCEval 的 answers 通常是 list 格式）
                gold_answers = row['answers']
                if isinstance(gold_answers, str):
                    gold_answers = [gold_answers] # 確保轉成 list 方便走訪
                
                # 建立臨時 RAG 檢索：如果目前有正式 RAG 庫，就用 RAG 搜尋；否則直接用該題的 context 當背景
                if st.session_state.get('vector_db'):
                    current_k = st.session_state.get('dynamic_k', 5)
                    search_context, _ = get_relevant_context(question, st.session_state['vector_db'], current_k)
                else:
                    search_context = context
                
                # 組織 Prompt 發送給 Ollama 模型
                system_instruction = """你現在是一位專業的企業行政助手。請根據提供的【手冊內容】精準回答問題。
